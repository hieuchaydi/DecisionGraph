DECISIONGRAPH_ENV=development
DECISIONGRAPH_DATA_PATH=data/decisiongraph.json
# Optional API protection:
# DECISIONGRAPH_API_TOKEN=change-me
# Optional enforcement (default true in production):
# DECISIONGRAPH_REQUIRE_TOKEN_IN_PRODUCTION=true
# Optional API rate limit per client per minute (0 to disable):
# DECISIONGRAPH_RATE_LIMIT_PER_MINUTE=240
# Optional CORS list:
# DECISIONGRAPH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
# Optional GitHub connector:
# DECISIONGRAPH_GITHUB_TOKEN=ghp_xxx
# DECISIONGRAPH_GITHUB_BASE_URL=https://api.github.com
# Legacy fallback still supported:
# SE_URL=https://api.github.com
# Optional Groq connector:
# GROQ_API_KEY=gsk_xxx
# GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
